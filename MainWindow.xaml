<Window x:Class="AutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoClicker"
        Height="600" Width="900"
        MinHeight="500" MinWidth="750"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Deactivated="Window_Deactivated">

    <Window.Resources>

        <!-- ===== Кнопка закрытия/сворачивания ===== -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Навигация Sidebar ===== -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    CornerRadius="8" Margin="8,2">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Border>
                            <Border x:Name="accentBar" Width="3" CornerRadius="1.5"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Left" Margin="0,8" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="accentBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Pill-переключатель (chip select) ===== -->
        <Style x:Key="PillRadio" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="17" Padding="16,0" MinWidth="80">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Акцентная кнопка ===== -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" Padding="24,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Второстепенная кнопка ===== -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Slider ===== -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" CornerRadius="3" Background="{StaticResource TertiaryBackgroundBrush}" VerticalAlignment="Center"/>
                            <Border x:Name="PART_SelectionRange" Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                 <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="18" Height="18" CornerRadius="9"
                                                        Background="{StaticResource AccentBrush}"
                                                        BorderBrush="#66FFFFFF" BorderThickness="2">
                                                    <Ellipse Width="8" Height="8" Fill="White"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Стиль элемента ListBox для пресетов ===== -->
        <Style x:Key="PresetListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Кастомный ScrollBar ===== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border x:Name="TrackBg" CornerRadius="4" Background="#2A2A2A"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="thumb" CornerRadius="4" Background="#555555" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumb" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumb" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Кастомный ScrollViewer (убирает горизонтальный скроллбар) ===== -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Анимация пульса для статуса ===== -->
        <Storyboard x:Key="StatusPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:1"
                             EasingFunction="{StaticResource PulseEasing}"/>
        </Storyboard>
        <SineEase x:Key="PulseEasing" EasingMode="EaseInOut"/>

        <!-- ===== Анимация.fade-in для страниц ===== -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ===== Стиль TextBox ===== -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <!-- ===== Стиль ComboBox ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="10,0">
                                <Grid>
                                    <ContentPresenter IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Left"
                                                      Margin="0"/>
                                    <ToggleButton x:Name="toggleButton"
                                                  Background="Transparent" BorderThickness="0"
                                                  HorizontalAlignment="Right" Width="24"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False">
                                        <Path Data="M0,0 L4,4 L8,0" Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="1.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="{StaticResource TertiaryBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Margin="0,4,0,0" Padding="0,4">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Стиль элемента выпадающего списка ===== -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ===================== ОСНОВНАЯ РАЗМЕТКА ===================== -->
    <Border CornerRadius="12" Background="{StaticResource PrimaryBackgroundBrush}" BorderBrush="#444444" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Grid Grid.Row="0" Background="#2A2A2A" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0">
                    <TextBlock Text="AutoClicker Pro" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== СОДЕРЖИМОЕ ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== SIDEBAR ===== -->
                <Border Grid.Column="0" Background="#222222" CornerRadius="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Статус -->
                        <Border Grid.Row="1" Margin="14,0,14,16" Padding="12"
                                Background="{StaticResource TertiaryBackgroundBrush}" CornerRadius="10">
                            <StackPanel>
                                <Ellipse x:Name="StatusIndicator" Width="10" Height="10"
                                         Fill="{StaticResource SecondaryTextBrush}"
                                         HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <TextBlock x:Name="StatusText" Text="Остановлен" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock x:Name="ClickCountText" Text="Кликов: 0" FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Навигация -->
                        <StackPanel Grid.Row="2">
                            <RadioButton Style="{StaticResource NavButton}" IsChecked="True" GroupName="Nav" Click="NavHome_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Главная" FontSize="13"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" GroupName="Nav" Click="NavSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Настройки" FontSize="13"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" GroupName="Nav" Click="NavPresets_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Пресеты" FontSize="13"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource NavButton}" GroupName="Nav" Click="NavAbout_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="О программе" FontSize="13"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Text="v1.0.0" FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    </Grid>
                </Border>

                <!-- ===== КОНТЕНТ ===== -->
                <Grid Grid.Column="1">

                    <!-- ==================== ГЛАВНАЯ ==================== -->
                    <Border x:Name="PageHome" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="36,28,36,28">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Управление автокликером" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,20"/>

                                <!-- Интервал | Тип ввода + Тип действия -->
                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Интервал (справа) -->
                                    <Border Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}"
                                            CornerRadius="12" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="ИНТЕРВАЛ" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBox x:Name="IntervalBox" Width="80" Height="36"
                                                         Text="100" FontSize="18" FontWeight="Bold"
                                                         Foreground="{StaticResource PrimaryTextBrush}"
                                                         Background="{StaticResource TertiaryBackgroundBrush}"
                                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                         TextAlignment="Center" VerticalContentAlignment="Center"
                                                         MaxLength="6" PreviewTextInput="IntervalBox_PreviewTextInput"/>
                                                <TextBlock x:Name="IntervalUnitLabel" Text="мс" FontSize="14" Margin="8,0,0,0"
                                                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                                <TextBlock x:Name="UnitMsLabel" Text="мс" FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Border Width="36" Height="20" CornerRadius="10"
                                                        Background="{StaticResource AccentBrush}"
                                                        Cursor="Hand" MouseLeftButtonDown="UnitToggle_Click">
                                                    <Ellipse x:Name="UnitToggleThumb" Width="16" Height="16"
                                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                                </Border>
                                                <TextBlock x:Name="UnitCpsLabel" Text="CPS" FontSize="12"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Быстро" FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Slider x:Name="IntervalSlider" Grid.Column="1"
                                                        Minimum="1" Maximum="2000" Value="100"
                                                        VerticalAlignment="Center" ValueChanged="IntervalSlider_ValueChanged"/>
                                                <TextBlock Grid.Column="2" Text="Медленно" FontSize="10"
                                                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Тип ввода + Тип действия (столбик) -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Тип ввода — pill -->
                                        <Border Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}"
                                                CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="ТИП ВВОДА" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <RadioButton x:Name="BtnInputMouse" Content="Мышь"
                                                                 IsChecked="True" GroupName="InputType"
                                                                 Style="{StaticResource PillRadio}"
                                                                 Click="InputType_Changed"/>
                                                    <RadioButton x:Name="BtnInputKeyboard" Content="Клавиатура"
                                                                 GroupName="InputType"
                                                                 Style="{StaticResource PillRadio}"
                                                                 Click="InputType_Changed"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Тип действия — pill -->
                                        <Border Grid.Row="2" Background="{StaticResource SecondaryBackgroundBrush}"
                                                CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="ТИП ДЕЙСТВИЯ" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <RadioButton x:Name="BtnSingleClick" Content="Одинарный"
                                                                 IsChecked="True" GroupName="ClickType"
                                                                 Style="{StaticResource PillRadio}"/>
                                                    <RadioButton x:Name="BtnDoubleClick" Content="Двойной"
                                                                 GroupName="ClickType"
                                                                 Style="{StaticResource PillRadio}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Кнопка мыши (Mouse) — pill -->
                                <Border x:Name="PanelMouseButtons" Grid.Row="2"
                                        Background="{StaticResource SecondaryBackgroundBrush}"
                                        CornerRadius="12" Padding="16" Margin="0,0,0,12" Visibility="Visible">
                                    <StackPanel>
                                        <TextBlock Text="КНОПКА МЫШИ" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <RadioButton x:Name="BtnLeftMouse" Content="Левая"
                                                         IsChecked="True" GroupName="MouseBtn"
                                                         Style="{StaticResource PillRadio}"/>
                                            <RadioButton x:Name="BtnRightMouse" Content="Правая"
                                                         GroupName="MouseBtn"
                                                         Style="{StaticResource PillRadio}"/>
                                            <RadioButton x:Name="BtnMiddleMouse" Content="Средняя"
                                                         GroupName="MouseBtn"
                                                         Style="{StaticResource PillRadio}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Режим работы — pill -->
                                <Border Grid.Row="3" Background="{StaticResource SecondaryBackgroundBrush}"
                                        CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="РЕЖИМ РАБОТЫ" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <RadioButton x:Name="BtnToggleMode" Content="Переключение (Toggle)"
                                                         IsChecked="True" GroupName="Mode"
                                                         Style="{StaticResource PillRadio}"/>
                                            <RadioButton x:Name="BtnHoldMode" Content="Удержание (Hold)"
                                                         GroupName="Mode"
                                                         Style="{StaticResource PillRadio}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Счётчик -->
                                <Border Grid.Row="4" Background="{StaticResource SecondaryBackgroundBrush}"
                                        CornerRadius="12" Padding="20" Margin="0,0,0,12" VerticalAlignment="Top">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ВСЕГО ДЕЙСТВИЙ" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock x:Name="TotalClickCount" Text="0" FontSize="32"
                                                       FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="ТЕКУЩИЕ/СЕК" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock x:Name="CurrentCps" Text="0.0" FontSize="32"
                                                       FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Кнопки управления -->
                                <Grid Grid.Row="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="StartStopButton"
                                            Style="{StaticResource AccentButton}"
                                            Click="StartStopButton_Click" Content="&#x25B6;  ЗАПУСТИТЬ"/>
                                    <Button Grid.Column="2" x:Name="ResetButton"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="ResetButton_Click" Content="Сбросить счётчик"/>
                                </Grid>

                                <!-- Режим ввода: Одна клавиша / Комбинация -->
                                <Border Grid.Row="6" Background="{StaticResource SecondaryBackgroundBrush}"
                                        CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="КЛАВИША / КОМБИНАЦИЯ" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="ComboKeyDisplay" Text="Не назначена"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Text="нажмите &quot;Назначить&quot; и введите комбинацию (например Ctrl+C)" FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" x:Name="ComboKeyBindBtn"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="160" Height="38"
                                                    Click="ComboKeyBind_Click"
                                                    Content="Назначить"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <!-- ==================== НАСТРОЙКИ ==================== -->
                    <Border x:Name="PageSettings" Visibility="Collapsed" Margin="36,28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Настройки" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,24"/>

                            <Border Grid.Row="1" Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12" Padding="20">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="ГОРЯЧИЕ КЛАВИШИ" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Старт / Стоп кликера" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="HotkeyStartStopBtn"
                                                Style="{StaticResource SecondaryButton}" Width="160" Height="36"
                                                Click="HotkeyStartStop_Click" Content="Нажмите для назначения"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Сброс счётчика" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="HotkeyResetBtn"
                                                Style="{StaticResource SecondaryButton}" Width="160" Height="36"
                                                Click="HotkeyReset_Click" Content="Нажмите для назначения"/>
                                    </Grid>

                                    <TextBlock Text="ДОПОЛНИТЕЛЬНО" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Звуковые эффекты" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                                Background="{StaticResource TertiaryBackgroundBrush}"
                                                Cursor="Hand" MouseLeftButtonDown="SoundToggle_Click">
                                            <Ellipse x:Name="SoundToggleThumb" Width="20" Height="20"
                                                     Fill="{StaticResource SecondaryTextBrush}"
                                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Анимации интерфейса" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                                Background="{StaticResource TertiaryBackgroundBrush}"
                                                Cursor="Hand" MouseLeftButtonDown="AnimationToggle_Click">
                                            <Ellipse x:Name="AnimationToggleThumb" Width="20" Height="20"
                                                     Fill="{StaticResource SecondaryTextBrush}"
                                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,16,0,16"/>

                                    <!-- Лимит кликов -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Лимит кликов" FontSize="14"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="лимит (0 = без ограничений)" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBox x:Name="ClickLimitBox" Grid.Column="1"
                                                 Width="80" Height="32" FontSize="14"
                                                 Text="0" TextAlignment="Center"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 Background="{StaticResource TertiaryBackgroundBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 VerticalContentAlignment="Center"
                                                 PreviewTextInput="ClickLimitBox_PreviewTextInput"
                                                 LostFocus="ClickLimitBox_LostFocus"/>
                                    </Grid>

                                    <!-- Рандомизация -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Рандомизация интервала" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                                Background="{StaticResource TertiaryBackgroundBrush}"
                                                Cursor="Hand" MouseLeftButtonDown="RandomToggle_Click">
                                            <Ellipse x:Name="RandomToggleThumb" Width="20" Height="20"
                                                     Fill="{StaticResource SecondaryTextBrush}"
                                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Процент отклонения (%)" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="RandomPercentBox" Grid.Column="1"
                                                 Width="60" Height="32" FontSize="14"
                                                 Text="10" TextAlignment="Center"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 Background="{StaticResource TertiaryBackgroundBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 VerticalContentAlignment="Center"
                                                 PreviewTextInput="RandomPercentBox_PreviewTextInput"
                                                 LostFocus="RandomPercentBox_LostFocus"/>
                                    </Grid>

                                    <!-- Привязка к окну -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Привязка к окну" FontSize="14"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="выберите окно (пусто = глобально)" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="WindowSelectorCombo" Grid.Column="1"
                                                  Width="200" Height="32" FontSize="13"
                                                  Foreground="{StaticResource PrimaryTextBrush}"
                                                  Background="{StaticResource TertiaryBackgroundBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  DisplayMemberPath="Title"
                                                  SelectionChanged="WindowSelector_SelectionChanged"/>
                                    </Grid>

                                    <!-- Сворачивать в трей -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Сворачивать в трей" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                                Background="{StaticResource TertiaryBackgroundBrush}"
                                                Cursor="Hand" MouseLeftButtonDown="TrayToggle_Click">
                                            <Ellipse x:Name="TrayToggleThumb" Width="20" Height="20"
                                                     Fill="{StaticResource SecondaryTextBrush}"
                                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                    </Grid>

                                    <!-- Запускать с Windows -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Запускать с Windows" FontSize="14"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                                Background="{StaticResource TertiaryBackgroundBrush}"
                                                Cursor="Hand" MouseLeftButtonDown="RealAutostartToggle_Click">
                                            <Ellipse x:Name="RealAutostartToggleThumb" Width="20" Height="20"
                                                     Fill="{StaticResource SecondaryTextBrush}"
                                                     HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ==================== ПРЕСЕТЫ ==================== -->
                    <Border x:Name="PagePresets" Visibility="Collapsed" Margin="36,28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Пресеты" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="Сохраняйте и загружайте конфигурации автокликера"
                                       FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,24"/>

                            <!-- Создать / Перезаписать -->
                            <Border Grid.Row="2" Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="СОХРАНИТЬ ПРЕСЕТ" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="PresetNameBox" Grid.Column="0"
                                                 Height="40" FontSize="14"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 Background="{StaticResource TertiaryBackgroundBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 VerticalContentAlignment="Center" Padding="12,0"
                                                 Text="" MaxLength="30"/>
                                        <Button Grid.Column="2" x:Name="SavePresetBtn"
                                                Style="{StaticResource AccentButton}" Height="40"
                                                Click="SavePreset_Click" Content="Сохранить"
                                                Padding="24,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Список пресетов -->
                            <Border Grid.Row="3" Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12" Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="МОИ ПРЕСЕТЫ" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                    <ListBox x:Name="PresetsList" Grid.Row="1"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            FontSize="14" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            SelectionChanged="PresetsList_SelectionChanged"
                                            ItemContainerStyle="{StaticResource PresetListBoxItemStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Кнопки управления -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="LoadPresetBtn"
                                        Style="{StaticResource AccentButton}" Height="42"
                                        Click="LoadPreset_Click" Content="Загрузить пресет"/>
                                <Button Grid.Column="2" x:Name="DeletePresetBtn"
                                        Style="{StaticResource SecondaryButton}" Height="42"
                                        Click="DeletePreset_Click" Content="Удалить выбранный"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ==================== О ПРОГРАММЕ ==================== -->
                    <Border x:Name="PageAbout" Visibility="Collapsed" Margin="36,28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="О программе" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,24"/>

                            <Border Grid.Row="1" Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12" Padding="24" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="AutoClicker Pro" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Версия 1.0.0" FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}">
                                        Продвинутый автокликер с глобальными горячими клавишами,
                                        настройкой интервала, выбором кнопки мыши и типов кликов.
                                        Дизайн в стиле Kaspersky.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Авторы -->
                            <Border Grid.Row="2" Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="АВТОР" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,12"/>

                                    <!-- Имя автора -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
