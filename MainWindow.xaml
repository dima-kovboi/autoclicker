                                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="dimakovboi" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>

